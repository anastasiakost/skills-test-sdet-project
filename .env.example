# Copy to .env and adjust. All values are validated at startup (src/config/env.ts).

# Application under test
BASE_URL=https://thinking-tester-contact-list.herokuapp.com

# Target environment label: local | ci | staging
ENV=local

# winston log level: error | warn | info | http | verbose | debug | silly
# Use debug locally when troubleshooting (logs request/response bodies).
LOG_LEVEL=info

# Show the browser during local e2e runs: true | false
# (CI always runs headless; `npm run test:headed` works regardless of this.)
HEADED=false
