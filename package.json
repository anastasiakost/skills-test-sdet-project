{
  "name": "skills-test-sdet",
  "version": "1.0.0",
  "description": "UI + API test automation framework for the Contact List app (Playwright + TypeScript)",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test --project=e2e",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --project=e2e --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-plugin-playwright": "^2.10.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  }
}
